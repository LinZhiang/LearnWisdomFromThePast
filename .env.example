# 前端环境变量（项目根目录 .env）
# DeepSeek 密钥已迁至 server/.env，勿在此填写 API Key。
# 完整说明见：docs/ENV-说明.md

# 生产构建必填：已部署的 AI 代理根路径（须以 /v1 结尾，无尾部斜杠）
# 例：https://你的-api域名.com/v1
# VITE_AI_API_BASE=

# 开发环境可不写：将自动通过 Vite 代理访问本机 server（默认 8787）

# 可选：按场景指定 DeepSeek 模型（不填则用代码内默认值）
# VITE_DEEPSEEK_MODEL_DEFAULT=deepseek-v4-flash
# VITE_DEEPSEEK_MODEL_HEAVY=deepseek-v4-pro
